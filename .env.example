# ==========================================
# CONFIGURACIÓN DE TELEGRAM
# ==========================================

# [REQUERIDO] Tu Token del Bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# [OPCIONAL] Lista de IDs permitidos separados por comas.
# Déjalo vacío para que cualquier persona pueda usar el bot.
ALLOWED_CHAT_IDS=123456789,987654321

# ==========================================
# CONFIGURACIÓN DE WHISPER (IA)
# ==========================================

# [OPCIONAL] Ruta temporal para procesar los audios.
# NOTA: Si usas Docker con nuestra configuración, pon /app/tmp
TMP_PATH=/tmp

# [OPCIONAL] Modelo de Whisper. 'small' es el más equilibrado.
# Opciones: tiny, base, small, medium, large-v3 (añade .en para modelos solo en inglés)
WHISPER_MODEL=small

# [OPCIONAL] Fuerza un idioma específico (ej: "es" para español, "en" para inglés).
# Déjalo vacío para detección automática.
AUDIO_LANGUAGE=

# [OPCIONAL] Traducir automáticamente cualquier audio al inglés.
# Ponlo en 'true' para traducir, o 'false' para transcribir en el idioma original.
WHISPER_TRANSLATE=false